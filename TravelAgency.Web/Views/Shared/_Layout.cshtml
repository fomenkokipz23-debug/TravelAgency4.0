<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TravelAgency.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TravelAgency.Web.styles.css" asp-append-version="true" />
    <style>
        .bg-purple-nav { 
            background-color: #6f42c1 !important; 
            height: 55px !important; 
            padding-top: 0 !important;
            padding-bottom: 0 !important;
            display: flex !important;
            align-items: center !important;
        }

        .navbar-custom-container {
            display: flex !important;
            align-items: center !important;
            justify-content: space-between !important;
            width: 100%;
        }
        
        .btn-outline-white-custom { 
            border: 2px solid #ffffff !important; 
            color: #6f42c1 !important; 
            background-color: #ffffff !important; 
            border-radius: 25px !important; 
            font-weight: 700 !important;
            padding: 5px 22px !important;
            font-size: 14px !important;
            text-decoration: none !important;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.12) !important;
            transition: all 0.2s ease-in-out !important;
            display: inline-block !important;
        }
        .btn-outline-white-custom:hover { 
            background-color: #f8f9fa !important;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.2) !important;
            transform: translateY(-1px);
        }
        
        .btn-white-custom { 
            background-color: #ffffff !important; 
            color: #6f42c1 !important; 
            border: none !important; 
            border-radius: 25px !important;
            font-weight: 700 !important;
            padding: 6px 24px !important;
            font-size: 14px !important;
            text-decoration: none !important;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.12) !important;
            transition: all 0.2s ease-in-out !important;
            display: inline-block !important;
        }
        .btn-white-custom:hover { 
            background-color: #f8f9fa !important;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.2) !important;
            transform: translateY(-1px);
        }

        .profile-link {
            color: #ffffff !important;
            text-decoration: none !important;
            font-weight: 600;
            font-size: 15px !important;
        }
        .profile-link:hover {
            opacity: 0.85;
        }

        body {
            position: relative;
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background-color: #f3f4f6;
            z-index: 1;
        }
        .bg-slideshow {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -2;
            list-style: none;
            margin: 0;
            padding: 0;
        }
        .bg-slideshow li {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            opacity: 0;
            z-index: -2;
            animation: imageFadeInOut 15s linear infinite;
        }
        .bg-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(243, 244, 246, 0.45); 
            z-index: -1;
        }
        .bg-slideshow li:nth-child(1) {
            background-image: url('https://images.unsplash.com/photo-1502602898657-3e91760cbb34?q=80&w=1920&auto=format&fit=crop');
            animation-delay: 0s;
        }
        .bg-slideshow li:nth-child(2) {
            background-image: url('https://images.unsplash.com/photo-1531210483974-4f8c1f33fd35?q=80&w=1920&auto=format&fit=crop');
            animation-delay: 5s;
        }
        .bg-slideshow li:nth-child(3) {
            background-image: url('https://images.unsplash.com/photo-1541943181603-d8fe267a5dcf?q=80&w=1920&auto=format&fit=crop');
            animation-delay: 10s;
        }
        @@keyframes imageFadeInOut {
            0% { opacity: 0; animation-timing-function: ease-in; }
            8% { opacity: 1; }
            33% { opacity: 1; }
            41% { opacity: 0; }
            100% { opacity: 0; }
        }
    </style>
</head>
<body>

    <ul class="bg-slideshow">
        <li></li>
        <li></li>
        <li></li>
    </ul>
    <div class="bg-overlay"></div>

    <header style="position: relative; z-index: 10;">
        <nav class="navbar navbar-expand-sm navbar-dark bg-purple-nav" style="box-shadow: 0 4px 12px rgba(111, 66, 193, 0.15);">
            <div class="container-fluid px-4 navbar-custom-container">
                
                <div class="d-flex align-items-center">
                    <a class="navbar-brand text-white fw-bold fs-4 me-4" asp-area="" asp-controller="Home" asp-action="Index" style="letter-spacing: -0.5px; margin-bottom: 0;">TravelAgency</a>
                    <ul class="navbar-nav d-none d-sm-flex">
                        <li class="nav-item">
                            <a class="nav-link text-white fw-medium m-0 p-0" asp-area="" asp-controller="Home" asp-action="Index">Головна</a>
                        </li>
                    </ul>
                </div>

                <div class="d-flex align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="me-3 text-white">
                            <a class="profile-link" asp-controller="Account" asp-action="Profile" style="cursor: pointer;">
                                <strong class="text-white text-decoration-underline">@User.Identity.Name</strong>
                            </a>
                        </div> 
                        <a class="btn-outline-white-custom" asp-controller="Account" asp-action="Logout">Вийти</a>
                    }
                    else
                    {
                        <a class="btn-white-custom" asp-controller="Account" asp-action="Register">Реєстрація / Вхід</a>
                    }
                </div>
                
            </div>
        </nav>
    </header>

    @{
        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
        var action = ViewContext.RouteData.Values["action"]?.ToString();
        
        bool hideFooter = (controller == "Home" && action == "Index") || 
                           (controller == "Home" && action == "Details");
    }

    <div class="container" style="position: relative; z-index: 5; margin-top: 25px;">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    @if (!hideFooter)
    {
        <footer class="border-top border-purple footer text-muted py-3 bg-white mt-auto" style="position: relative; z-index: 5;">
            <div class="container text-center">
                &copy; 2026 - TravelAgency.Web
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>