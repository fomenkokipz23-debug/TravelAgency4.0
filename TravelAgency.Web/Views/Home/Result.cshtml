@{
    ViewData["Title"] = "Рахунок сформовано";
}

<div class="container mt-5 d-flex justify-content-center">
    <div class="card p-4 shadow border-0 text-center" style="max-width: 550px; width: 100%; background-color: #fcfaff; border-radius: 8px;">
        
        <h2 class="text-purple mb-4" style="font-weight: 600; font-family: 'Segoe UI', sans-serif;">
            Бронювання успішне!
        </h2>
        
        <div class="text-start p-3 bg-white rounded border" 
             style="font-family: 'Courier New', Courier, monospace; font-size: 1.05rem; color: #333; line-height: 1.6; border-color: #e2d9f3 !important;">
            
            <div class="text-center mb-2">--- РАХУНОК ДЛЯ: @ViewBag.ClientNameForReceipt ---</div>
            
            <div><strong>Тур:</strong> @ViewBag.TourName</div>
            <div style="word-wrap: break-word;"><strong>Маршрут:</strong> @ViewBag.Route</div>
            <div><strong>Тариф:</strong> @ViewBag.TariffName</div>
            
            <div><strong>Виїзд:</strong> @ViewBag.DepartureDate</div>
            <div><strong>Приїзд:</strong> @ViewBag.ArrivalDate</div>
            
            <div class="mt-2 border-top pt-2 text-secondary" style="font-size: 0.95rem; white-space: pre-line;">
                @ViewBag.BuilderDetails
            </div>
            
            <div class="mt-3" style="border-top: 1px dashed #6f42c1; letter-spacing: 1px;"></div>
            
            <div class="mt-3 text-uppercase fs-5 text-purple" style="font-weight: bold;">
                ЗАГАЛОМ ДО СПЛАТИ: @ViewBag.TotalCost грн
            </div>
            
        </div>

        <div class="mt-4">
            <a href="/" class="btn btn-purple px-4 py-2" style="border-radius: 6px; font-weight: 500;">
                Повернутись до турів
            </a>
        </div>
        
    </div>
</div>