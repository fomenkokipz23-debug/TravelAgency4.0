@model TravelAgency.Domain.Tour
@{
    ViewData["Title"] = Model.Name;
    DateTime dep = DateTime.Today.AddDays(5);
    DateTime arr = dep.AddDays(6);
}

<div class="container py-5" style="max-width: 900px;">
    <div class="card border-0 p-4 shadow-sm mb-4" style="border-radius: 20px; background: #ffffff;">
        
        <h1 class="fw-bold text-purple mb-3">@Model.Name.Split('(')[0].Trim()</h1>
        <p class="text-muted mb-4" style="font-size: 1.1rem; line-height: 1.7;">@Model.Description</p>
        
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="p-3 rounded border" style="background: #F9F7FD; border-color: #E2D9F3;">
                    <span class="text-muted d-block small">Маршрут подорожі</span>
                    <strong class="text-dark">@Model.TourRoute.GetFullRouteString()</strong>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-3 rounded border" style="background: #F9F7FD; border-color: #E2D9F3;">
                    <span class="text-muted d-block small">Період відпочинку</span>
                    <strong class="text-dark">@dep.ToString("dd.MM.yyyy") — @arr.ToString("dd.MM.yyyy")</strong>
                </div>
            </div>
        </div>

        <h4 class="fw-bold text-dark mb-3">Варіанти проживання для вибору</h4>
        <div class="row g-3 mb-5">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; overflow: hidden;">
                    <img src="@Model.HotelImage3Star" class="card-img-top" style="height: 200px; object-fit: cover;" alt="Стандартний готель">
                    <div class="card-body p-3 bg-light">
                        <h5 class="fw-bold text-dark mb-1">Стандарт Варіант 3*</h5>
                        <p class="small text-muted mb-0">Затишні класичні номери, сніданок включено.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; overflow: hidden;">
                    <img src="@Model.HotelImage5Star" class="card-img-top" style="height: 200px; object-fit: cover;" alt="Люкс готель">
                    <div class="card-body p-3 bg-light">
                        <h5 class="fw-bold text-purple mb-1">Преміум Люкс 5*</h5>
                        <p class="small text-muted mb-0">Розкішний інтер'єр, SPA-зона, перша лінія.</p>
                    </div>
                </div>
            </div>
        </div>

        <form action="/Home/BuildTrip" method="post" class="border-top pt-4" style="border-color: #F0EAFB !important;">
            <input type="hidden" name="tourName" value="@Model.Name" />
            <input type="hidden" name="formattedDeparture" value="@dep.ToString("dd.MM.yyyy")" />
            <input type="hidden" name="formattedArrival" value="@arr.ToString("dd.MM.yyyy")" />

            <h4 class="fw-bold text-dark mb-3">Персоналізуйте свій пакет послуг</h4>
            
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-muted text-uppercase">Клас перельоту</label>
                    <select name="flightClass" class="form-select py-2 live-calc" style="border-radius: 8px; border-color: #E2D9F3;">
                        <option value="Standard" data-price="0">Стандарт-клас (0 грн)</option>
                        <option value="Comfort" data-price="3500">Комфорт-клас (+3500 грн)</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-muted text-uppercase">Категорія готелю</label>
                    <select name="hotelStars" class="form-select py-2 live-calc" style="border-radius: 8px; border-color: #E2D9F3;">
                        <option value="None" data-price="0">Без проживання</option>
                        <option value="3Star" data-price="1800">Готель 3* (+1800 грн)</option>
                        <option value="5Star" data-price="4500">Готель 5* (+4500 грн)</option>
                    </select>
                </div>
            </div>

            <div class="d-flex align-items-center justify-content-between p-3 mb-4" style="background: #FAFAFA; border-radius: 10px; border: 1px solid #E6E6E6;">
                <label class="form-check-label fw-medium text-dark mb-0" for="excCheck" style="cursor: pointer;">
                    Додати повну екскурсійну програму по маршруту (+1500 грн)
                </label>
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input live-calc" type="checkbox" name="withExcursion" value="Yes" id="excCheck" data-price="1500" style="cursor: pointer; width: 2.5em; height: 1.25em;">
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center bg-light p-3 rounded mb-4" style="border: 1px dashed #6f42c1;">
                <span class="text-dark fw-bold">Вартість туру (з урахуванням тарифу):</span>
                <span class="fs-4 fw-bold text-purple">
                    <span id="livePriceValue">@ViewBag.CalculatedBasePrice</span> грн
                </span>
            </div>

            <button type="submit" class="btn btn-purple w-100 py-3 fw-bold fs-5 shadow-sm" style="border-radius: 12px;">
                Підтвердити конфігурацію та придбати
            </button>
        </form>

    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const baseCalculatedPrice = parseFloat("@ViewBag.CalculatedBasePrice".replace(',', '.'));
            
            const inputs = document.querySelectorAll(".live-calc");
            const priceDisplay = document.getElementById("livePriceValue");

            function calculateLivePrice() {
                let currentTotal = baseCalculatedPrice;

                inputs.forEach(input => {
                    if (input.tagName === "SELECT") {
                        const selectedOption = input.options[input.selectedIndex];
                        const priceModifier = parseFloat(selectedOption.getAttribute("data-price")) || 0;
                        currentTotal += priceModifier;
                    } 
                    else if (input.tagName === "INPUT" && input.type === "checkbox") {
                        if (input.checked) {
                            const priceModifier = parseFloat(input.getAttribute("data-price")) || 0;
                            currentTotal += priceModifier;
                        }
                    }
                });

                priceDisplay.innerText = Math.round(currentTotal).toLocaleString('uk-UA');
            }

            inputs.forEach(input => {
                input.addEventListener("change", calculateLivePrice);
            });

            calculateLivePrice();
        });
    </script>
}